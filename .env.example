# MailerSend Configuration
# 1. Crea una cuenta gratis en https://www.mailersend.com/
# 2. Verifica tu dominio (o usa el subdominio de prueba que te dan al registrarte)
# 3. Ve a Settings -> API Tokens y crea un nuevo token
# 4. Copia los valores aquí (sin comillas)

VITE_MAILERSEND_API_TOKEN=tu_api_token_aqui
VITE_MAILERSEND_FROM_EMAIL=noreply@trial-xxxxx.mlsend.com
