line: 2px solid var(--color-primary, #0071e3);\n  outline-offset: 2px;\n}\n.btn-primary--block[data-v-9ba09709] { width: 100%;\n}\n\n/* Sizes */\n.btn-primary--sm[data-v-9ba09709] { padding: 0.5rem 1rem; font-size: 0.8125rem;\n}\n.btn-primary--md[data-v-9ba09709] { padding: 0.875rem 1.75rem; font-size: 0.875rem;\n}\n.btn-primary--lg[data-v-9ba09709] { padding: 1rem 2rem; font-size: 1rem;\n}\n\n/* Variants */\n.btn-primary--primary[data-v-9ba09709] {\n  background: var(--color-midnight, #0A1022);\n  color: #fff;\n  border-color: var(--color-midnight, #0A1022);\n}\n.btn-primary--primary[data-v-9ba09709]:hover:not(:disabled) {\n  background: var(--color-primary, #0071e3);\n  border-color: var(--color-primary, #0071e3);\n  transform: translateY(-1px);\n}\n.btn-primary--secondary[data-v-9ba09709] {\n  background: #fff;\n  color: var(--color-midnight, #0A1022);\n  border-color: var(--color-borderline, #E8EDF5);\n}\n.btn-primary--secondary[data-v-9ba09709]:hover:not(:disabled) {\n  border-color: var(--color-midnight, #0A1022);\n  transform: translateY(-1px);\n}\n.btn-primary--accent[data-v-9ba09709] {\n  background: var(--color-primary, #0071e3);\n  color: #fff;\n  border-color: var(--color-primary, #0071e3);\n}\n.btn-primary--accent[data-v-9ba09709]:hover:not(:disabled) {\n  background: var(--color-accent-hover, #0077ed);\n  border-color: var(--color-accent-hover, #0077ed);\n  transform: translateY(-1px);\n}\n.btn-primary--ghost[data-v-9ba09709] {\n  background: transparent;\n  color: #fff;\n  border-color: rgba(255, 255, 255, 0.3);\n}\n.btn-primary--ghost[data-v-9ba09709]:hover:not(:disabled) {\n  background: rgba(255, 255, 255, 0.08);\n  border-color: rgba(255, 255, 255, 0.6);\n}\n.btn-primary--danger[data-v-9ba09709] {\n  background: var(--color-error, #EF4444);\n  color: #fff;\n  border-color: var(--color-error, #EF4444);\n}\n.btn-primary--danger[data-v-9ba09709]:hover:not(:disabled) {\n  filter: brightness(1.1);\n  transform: translateY(-1px);\n}\n.btn-primary__icon[